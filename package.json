{
  "name": "autotranscribe2",
  "version": "0.1.0",
  "description": "AutoTranscribe2 CLI and core library for high-quality Dutch transcription on Apple Silicon.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "autotranscribe": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/__tests__/TranscriptTitleFormatter.test.js",
    "test:integration": "npm run build && node --test dist/__tests__/TranscribeIntegration.test.js",
    "title:preview": "npm run build && node dist/cli/titlePreview.js",
    "ingest:jpr": "npm run build && node dist/cli/ingestJustPressRecord.js",
    "start:all": "npm run build && node dist/cli/startAll.js",
    "stop:all": "node dist/cli/stopAll.js",
    "autostart:install": "npm run build && node dist/cli/autostartInstall.js",
    "start": "node ./dist/cli/index.js",
    "watch": "tsc -w"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}

